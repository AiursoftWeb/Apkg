@model Aiursoft.Apkg.Models.MirrorsViewModels.CreateViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["Add New Mirror"]</h3>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label asp-for="BaseUrl" class="form-label">@Localizer["Base URL"]</label>
                <input asp-for="BaseUrl" class="form-control" placeholder="https://mirror.aiursoft.com/ubuntu/" required />
                <span asp-validation-for="BaseUrl" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Suite" class="form-label">@Localizer["Suite"]</label>
                <input asp-for="Suite" class="form-control" placeholder="questing" required />
                <span asp-validation-for="Suite" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Component" class="form-label">@Localizer["Component"]</label>
                <input asp-for="Component" class="form-control" placeholder="main" required />
                <span asp-validation-for="Component" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Architecture" class="form-label">@Localizer["Architecture"]</label>
                <input asp-for="Architecture" class="form-control" placeholder="amd64" required />
                <span asp-validation-for="Architecture" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="SignedBy" class="form-label">@Localizer["Signed By (Optional)"]</label>
                <input asp-for="SignedBy" class="form-control" placeholder="/usr/share/keyrings/ubuntu-archive-keyring.gpg" />
                <span asp-validation-for="SignedBy" class="text-danger small"></span>
            </div>
            
            <div class="text-end">
                <a asp-action="Index" class="btn btn-secondary">@Localizer["Back to List"]</a>
                <button type="submit" class="btn btn-primary">@Localizer["Create"]</button>
            </div>
        </form>
    </div>
</div>

@if (ViewData.ModelState.Any(m => m.Value != null && m.Value.Errors.Any()))
{
    <div class="alert alert-danger mt-3">
        <div asp-validation-summary="All"></div>
    </div>
}
