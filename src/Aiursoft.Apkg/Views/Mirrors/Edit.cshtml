@model Aiursoft.Apkg.Models.MirrorsViewModels.EditViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["Edit Mirror"]</h3>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="BaseUrl" class="form-label">@Localizer["Base URL"]</label>
                <input asp-for="BaseUrl" class="form-control" required />
                <span asp-validation-for="BaseUrl" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Suite" class="form-label">@Localizer["Suite"]</label>
                <input asp-for="Suite" class="form-control" required />
                <span asp-validation-for="Suite" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Components" class="form-label">@Localizer["Components"]</label>
                <input asp-for="Components" class="form-control" required />
                <span asp-validation-for="Components" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="SignedBy" class="form-label">@Localizer["Signed By (Optional)"]</label>
                <input asp-for="SignedBy" class="form-control" />
                <span asp-validation-for="SignedBy" class="text-danger small"></span>
            </div>
            
            <div class="text-end">
                <a asp-action="Index" class="btn btn-secondary">@Localizer["Back to List"]</a>
                <button type="submit" class="btn btn-primary">@Localizer["Save Changes"]</button>
            </div>
        </form>
    </div>
</div>

@if (ViewData.ModelState.Any(m => m.Value != null && m.Value.Errors.Any()))
{
    <div class="alert alert-danger mt-3">
        <div asp-validation-summary="All"></div>
    </div>
}
