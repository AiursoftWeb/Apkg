@using Aiursoft.Apkg.Models.LocalPackagesViewModels
@model Aiursoft.Apkg.Models.ApkgUploadsViewModels.ApkgUploadsDetailsViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-2">
            <i class="align-middle me-1" data-lucide="arrow-left"></i>
            Back to Packages
        </a>
    </div>
    <div class="col-auto">
        <h3 class="mb-0">@Model.Upload.Package</h3>
    </div>
    <div class="col-auto">
        @if (Model.Upload.IsListed)
        {
            <span class="badge bg-success">Listed</span>
        }
        else
        {
            <span class="badge bg-secondary">Unlisted</span>
        }
    </div>
</div>

<div class="row">
    <div class="col-xl-10">
        @{
            var skippedWarnings = TempData["SkippedRepoWarnings"] as string;
            if (!string.IsNullOrWhiteSpace(skippedWarnings))
            {
                <div class="alert alert-warning d-flex align-items-start gap-2 mb-3" role="alert">
                    <i data-lucide="triangle-alert" style="width:18px;height:18px;flex-shrink:0;margin-top:2px;"></i>
                    <div>
                        <strong>Some repositories were skipped during publish</strong> because you do not have permission to upload to them:
                        <ul class="mb-0 mt-1">
                            @foreach (var repo in skippedWarnings.Split('|', StringSplitOptions.RemoveEmptyEntries))
                            {
                                <li><code>@repo</code></li>
                            }
                        </ul>
                    </div>
                </div>
            }
        }
        <div class="card">
            <div class="card-header">
                <ul class="nav nav-tabs card-header-tabs">
                    <li class="nav-item">
                        <a class="nav-link @(Model.ActiveTab == "overview" ? "active" : "")"
                           asp-action="Details" asp-route-id="@Model.Upload.Id" asp-route-tab="overview">
                            <i class="align-middle me-1" data-lucide="info"></i> Overview
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Model.ActiveTab == "versions" ? "active" : "")"
                           asp-action="Details" asp-route-id="@Model.Upload.Id" asp-route-tab="versions">
                            <i class="align-middle me-1" data-lucide="history"></i> Versions
                            <span class="badge bg-secondary ms-1">@Model.VersionHistory.Count</span>
                        </a>
                    </li>
                </ul>
            </div>
            <div class="card-body">
                @if (Model.ActiveTab == "overview")
                {
                    @* ── Overview Tab ── *@
                    @if (!Model.Upload.IsPublished)
                    {
                        <div class="alert alert-warning d-flex align-items-center gap-2 mb-3" role="alert">
                            <i data-lucide="clock" style="width:18px;height:18px;flex-shrink:0;"></i>
                            <div>
                                This upload is a <strong>draft</strong> and has not been published yet. No packages have been generated.
                                @if (!string.IsNullOrWhiteSpace(Model.Upload.VaultPath))
                                {
                                    <a asp-action="Preview" asp-route-vaultPath="@Model.Upload.VaultPath" class="alert-link ms-1">Go to Preview to Publish →</a>
                                }
                            </div>
                        </div>
                    }
                    @if (Model.LatestVersionId.HasValue && Model.Upload.Id != Model.LatestVersionId)
                    {
                        <div class="alert alert-info d-flex align-items-center gap-2 mb-3" role="alert">
                            <i data-lucide="info" style="width:18px;height:18px;flex-shrink:0;"></i>
                            <div>
                                A newer version of <strong>@Model.Upload.Package</strong> was uploaded.
                                <a asp-action="Details" asp-route-id="@Model.LatestVersionId" class="alert-link ms-1">View the latest version →</a>
                            </div>
                        </div>
                    }
                    <div class="row g-3 mb-3">
                        <div class="col-md-3">
                            <label class="form-label text-muted">Component</label>
                            <div><span class="badge bg-dark">@Model.Upload.Component</span></div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label text-muted">Uploaded At</label>
                            <div>@Model.Upload.UploadedAt.ToString("yyyy/M/d HH:mm") UTC</div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label text-muted">Uploader</label>
                            <div>@(Model.Upload.UploadedByUser?.UserName ?? "—")</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted">Maintainer</label>
                            <div>@(string.IsNullOrWhiteSpace(Model.Upload.Maintainer) ? "—" : Model.Upload.Maintainer)</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted">Homepage</label>
                            <div>
                                @if (string.IsNullOrWhiteSpace(Model.Upload.Homepage))
                                {
                                    <span>—</span>
                                }
                                else
                                {
                                    <a href="@Model.Upload.Homepage" target="_blank" rel="noopener noreferrer">@Model.Upload.Homepage</a>
                                }
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label text-muted">Description</label>
                            <div>@(string.IsNullOrWhiteSpace(Model.Upload.Description) ? "—" : Model.Upload.Description)</div>
                        </div>
                    </div>

                    <hr />
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        @if (Model.Upload.IsListed && (Model.IsOwner || Model.IsAdmin))
                        {
                            <form method="post" asp-action="Unlist" asp-route-id="@Model.Upload.Id">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-warning">Unlist</button>
                            </form>
                        }
                        else if (!Model.Upload.IsListed && Model.IsAdmin)
                        {
                            <form method="post" asp-action="Relist" asp-route-id="@Model.Upload.Id">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success">Relist</button>
                            </form>
                        }

                        @if (Model.IsAdmin)
                        {
                            <form method="post" asp-action="Delete" asp-route-id="@Model.Upload.Id">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger">Delete</button>
                            </form>
                        }
                    </div>

                    <h6 class="mb-3">Generated Local Packages</h6>
                    @if (!Model.Packages.Any())
                    {
                        <p class="text-muted mb-0">No Local Packages were generated for this upload.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Package</th>
                                        <th>Version</th>
                                        <th>Architecture</th>
                                        <th>Distro</th>
                                        <th>Suite</th>
                                        <th>Sync Status</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var info in Model.Packages)
                                    {
                                        var pkg = info.Package;
                                        <tr>
                                            <td><strong>@pkg.Package</strong></td>
                                            <td><span class="badge bg-info">@pkg.Version</span></td>
                                            <td><span class="badge bg-dark">@pkg.Architecture</span></td>
                                            <td><small>@(pkg.Repository?.Distro ?? "—")</small></td>
                                            <td><small>@(pkg.Repository?.Suite ?? "—")</small></td>
                                            <td>
                                                @switch (info.Status)
                                                {
                                                    case LocalPackageStatus.Live:
                                                        <span class="badge bg-success" title="@info.StatusMessage">
                                                            <i class="align-middle me-1" data-lucide="check-circle" style="width:12px; height:12px;"></i> Live
                                                        </span>
                                                        break;
                                                    case LocalPackageStatus.StagedForSigning:
                                                        <span class="badge bg-info" title="@info.StatusMessage">
                                                            <i class="align-middle me-1" data-lucide="clock" style="width:12px; height:12px;"></i> Staged
                                                        </span>
                                                        break;
                                                    case LocalPackageStatus.PendingSync:
                                                        <span class="badge bg-warning text-dark" title="@info.StatusMessage">
                                                            <i class="align-middle me-1" data-lucide="refresh-cw" style="width:12px; height:12px;"></i> Pending Sync
                                                        </span>
                                                        break;
                                                    case LocalPackageStatus.Superseded:
                                                        <span class="badge bg-secondary" title="@info.StatusMessage">
                                                            <i class="align-middle me-1" data-lucide="archive" style="width:12px; height:12px;"></i> Superseded
                                                        </span>
                                                        break;
                                                    case LocalPackageStatus.Disabled:
                                                        <span class="badge bg-secondary" title="@info.StatusMessage">
                                                            <i class="align-middle me-1" data-lucide="slash" style="width:12px; height:12px;"></i> Disabled
                                                        </span>
                                                        break;
                                                }
                                            </td>
                                            <td class="text-end">
                                                @if (info.Status == LocalPackageStatus.Live && info.LivePackageId.HasValue)
                                                {
                                                    <a asp-controller="Repositories" asp-action="PackageDetails" asp-route-id="@info.LivePackageId.Value" class="btn btn-sm btn-outline-info">
                                                        <i class="align-middle" data-lucide="external-link"></i>
                                                    </a>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
                else
                {
                    @* ── Versions Tab ── *@
                    @if (!Model.VersionHistory.Any())
                    {
                        <p class="text-muted mb-0">No versions found.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Version</th>
                                        <th>Component</th>
                                        <th>Status</th>
                                        <th>Uploaded</th>
                                        @if (Model.IsAdmin)
                                        {
                                            <th>Uploader</th>
                                        }
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var v in Model.VersionHistory)
                                    {
                                        var uploadVersions = v.Packages.Select(p => p.Version).Distinct().ToList();
                                        var isLive = uploadVersions.Any(ver => Model.LiveVersions.Contains(ver));
                                        var isDraft = !v.IsPublished;
                                        var rowStatus = !v.IsListed
                                            ? "Unlisted"
                                            : isDraft
                                                ? "Draft"
                                                : isLive ? "Live" : "Superseded";
                                        var rowClass = !v.IsListed || isDraft
                                            ? "bg-secondary"
                                            : isLive ? "bg-success" : "bg-secondary";
                                        var isCurrent = v.Id == Model.Upload.Id;
                                        <tr class="@(isCurrent ? "table-active" : "")">
                                            <td>
                                                @if (uploadVersions.Count > 0)
                                                {
                                                    foreach (var ver in uploadVersions)
                                                    {
                                                        <span class="badge bg-info">@ver</span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                                @if (Model.LatestVersionId == v.Id)
                                                {
                                                    <span class="badge bg-success ms-1">Newest</span>
                                                }
                                                @if (isCurrent)
                                                {
                                                    <small class="text-muted ms-1">(current view)</small>
                                                }
                                            </td>
                                            <td><span class="badge bg-dark">@v.Component</span></td>
                                            <td>
                                                @if (rowStatus == "Superseded")
                                                {
                                                    <span class="badge @rowClass"
                                                          data-bs-toggle="tooltip"
                                                          title="This version's packages are superseded. They remain in storage until garbage collection removes unreferenced content.">
                                                        @rowStatus
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge @rowClass">@rowStatus</span>
                                                }
                                            </td>
                                            <td><small class="text-muted">@v.UploadedAt.ToString("yyyy/M/d HH:mm")</small></td>
                                            @if (Model.IsAdmin)
                                            {
                                                <td><small>@(v.UploadedByUser?.UserName ?? "—")</small></td>
                                            }
                                            <td class="text-end">
                                                <div class="btn-group">
                                                    <a asp-action="Details" asp-route-id="@v.Id" class="btn btn-sm btn-outline-info" title="View Details">
                                                        <i class="align-middle" data-lucide="eye"></i>
                                                    </a>
                                                    @if (v.IsListed && (Model.IsOwner || Model.IsAdmin))
                                                    {
                                                        <button type="button" class="btn btn-sm btn-outline-warning" data-bs-toggle="modal" data-bs-target="#unlistUpload-@v.Id" title="Unlist">
                                                            <i class="align-middle" data-lucide="archive-x"></i>
                                                        </button>
                                                    }
                                                    @if (Model.IsAdmin)
                                                    {
                                                        <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteUpload-@v.Id" title="Delete">
                                                            <i class="align-middle" data-lucide="trash-2"></i>
                                                        </button>
                                                    }
                                                </div>

                                                @if (v.IsListed && (Model.IsOwner || Model.IsAdmin))
                                                {
                                                    <div class="modal fade" id="unlistUpload-@v.Id" tabindex="-1" aria-hidden="true">
                                                        <div class="modal-dialog">
                                                            <div class="modal-content text-start">
                                                                <div class="modal-header">
                                                                    <h5 class="modal-title">Confirm Unlist</h5>
                                                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                                </div>
                                                                <div class="modal-body">
                                                                    Unlist <strong>@v.Package</strong>? Generated packages will be disabled.
                                                                </div>
                                                                <div class="modal-footer">
                                                                    <form method="post" asp-action="Unlist" asp-route-id="@v.Id">
                                                                        @Html.AntiForgeryToken()
                                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                                        <button type="submit" class="btn btn-warning">Unlist</button>
                                                                    </form>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                }

                                                @if (Model.IsAdmin)
                                                {
                                                    <div class="modal fade" id="deleteUpload-@v.Id" tabindex="-1" aria-hidden="true">
                                                        <div class="modal-dialog">
                                                            <div class="modal-content text-start">
                                                                <div class="modal-header">
                                                                    <h5 class="modal-title">Confirm Delete</h5>
                                                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                                </div>
                                                                <div class="modal-body">
                                                                    Permanently delete <strong>@v.Package</strong> and all generated LocalPackages?
                                                                </div>
                                                                <div class="modal-footer">
                                                                    <form method="post" asp-action="Delete" asp-route-id="@v.Id">
                                                                        @Html.AntiForgeryToken()
                                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                                        <button type="submit" class="btn btn-danger">Delete</button>
                                                                    </form>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
    <div class="d-none d-xl-block col-xl-2">
        <div class="card mb-3 border-primary">
            <div class="card-body">
                <div class="text-center mb-3">
                    <i data-lucide="inbox" style="width:48px;height:48px;"></i>
                </div>
                <h6 class="mb-2">@Localizer["What is an Upload?"]</h6>
                <p class="text-muted small mb-2">@Localizer["An APKG Upload is a .apkg bundle pushed by a user via CLI or Web UI. The server unpacks it into LocalPackages and syncs them to APT repositories."]</p>
                <p class="text-muted small mb-0"><strong>@Localizer["Tip:"]</strong> @Localizer["Listed packages are publicly visible; unlisted ones are hidden until an admin publishes them."]</p>
            </div>
        </div>
    </div>
</div>
