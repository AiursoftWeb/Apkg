@model Aiursoft.Apkg.Models.ApkgPackagesViewModels.ApkgPackagesPreviewViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto">
        <h3>@Localizer["Preview APKG Upload"]</h3>
    </div>
</div>

@if (ViewData.ModelState.ErrorCount > 0)
{
    <div class="alert alert-danger">
        <div asp-validation-summary="All"></div>
    </div>
}

@if (Model.AllTargetsUnmatched)
{
    <div class="alert alert-warning d-flex align-items-start" role="alert">
        <div class="alert-icon me-3">
            <i data-lucide="alert-triangle" style="width:24px;height:24px;"></i>
        </div>
        <div class="alert-message">
            @Localizer["No targets matched any repository. Publishing will have no effect."]
        </div>
    </div>
}
else if (Model.HasWarnings)
{
    <div class="alert alert-warning d-flex align-items-start" role="alert">
        <div class="alert-icon me-3">
            <i data-lucide="alert-triangle" style="width:24px;height:24px;"></i>
        </div>
        <div class="alert-message">
            @Localizer["Some targets do not match any repository. You can still publish, but those targets will be skipped."]
        </div>
    </div>
}

<div class="card mb-3">
    <div class="card-header">@Localizer["Manifest"]</div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label text-muted">@Localizer["Package"]</label>
                <div><strong>@Model.Manifest.Name</strong></div>
            </div>
            <div class="col-md-4">
                <label class="form-label text-muted">@Localizer["Distro"]</label>
                <div><span class="badge bg-dark">@Model.Manifest.Distro</span></div>
            </div>
            <div class="col-md-4">
                <label class="form-label text-muted">@Localizer["Component"]</label>
                <div><span class="badge bg-dark">@Model.Manifest.Component</span></div>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted">@Localizer["Maintainer"]</label>
                <div>@(string.IsNullOrWhiteSpace(Model.Manifest.Maintainer) ? Localizer["—"].Value : Model.Manifest.Maintainer)</div>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted">@Localizer["Homepage"]</label>
                <div>
                    @if (string.IsNullOrWhiteSpace(Model.Manifest.Homepage))
                    {
                        <span>@Localizer["—"]</span>
                    }
                    else
                    {
                        <a href="@Model.Manifest.Homepage" target="_blank" rel="noopener noreferrer">@Model.Manifest.Homepage</a>
                    }
                </div>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted">@Localizer["License"]</label>
                <div>@(string.IsNullOrWhiteSpace(Model.Manifest.License) ? Localizer["—"].Value : Model.Manifest.License)</div>
            </div>
            <div class="col-12">
                <label class="form-label text-muted">@Localizer["Description"]</label>
                <div>@(string.IsNullOrWhiteSpace(Model.Manifest.Description) ? Localizer["—"].Value : Model.Manifest.Description)</div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">@Localizer["Targets"]</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>@Localizer["Target"]</th>
                        <th>@Localizer["Distro"]</th>
                        <th>@Localizer["Suites"]</th>
                        <th>@Localizer["Arch"]</th>
                        <th>@Localizer["Matching Repos"]</th>
                        <th>@Localizer["Status"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Targets)
                    {
                        <tr>
                            <td><code>@item.Entry.DebFile</code></td>
                            <td>@Model.Manifest.Distro</td>
                            <td>@item.Entry.Suite</td>
                            <td><span class="badge bg-dark">@item.Entry.Architecture</span></td>
                            <td>
                                @if (item.HasMatch)
                                {
                                    <div class="d-flex flex-wrap gap-1">
                                        @foreach (var repo in item.MatchingRepositories)
                                        {
                                            <span class="badge bg-light text-dark border">@repo.Name (@repo.Suite)</span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-warning">@Localizer["No matching repository"]</span>
                                }
                            </td>
                            <td>
                                @if (item.HasMatch)
                                {
                                    <span class="badge bg-success">@Localizer["Ready"]</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">@Localizer["Warning"]</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <hr />
        <form asp-action="Publish" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="vaultPath" value="@Model.TempApkgFileInVaultPath" />
            <input type="hidden" name="fileName" value="@Model.FileName" />
            <button type="submit" class="btn btn-primary">@Localizer["Publish"]</button>
        </form>
    </div>
</div>
