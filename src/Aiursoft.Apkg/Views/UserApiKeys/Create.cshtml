@model Aiursoft.Apkg.Models.UserApiKeysViewModels.UserApiKeysCreateViewModel

<div class="container-fluid p-0">
    <div class="row mb-3">
        <div class="col-auto">
            <h1 class="h3 mb-3">@Localizer["Create New API Key"]</h1>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">@Localizer["New Key Details"]</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">@Localizer["Friendly Name"]</label>
                            <input asp-for="Name" class="form-control"
                                   placeholder="@Localizer["e.g. CI/CD Pipeline, Dev Machine"]" autofocus />
                            <span asp-validation-for="Name" class="text-danger"></span>
                            <div class="form-text">@Localizer["A label to help you identify where this key is used."]</div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="ExpirationDays" class="form-label">@Localizer["Expiration"]</label>
                            <select asp-for="ExpirationDays" class="form-select">
                                <option value="1">@Localizer["1 Day"]</option>
                                <option value="7">@Localizer["1 Week"]</option>
                                <option value="30">@Localizer["1 Month"]</option>
                                <option value="365" selected>@Localizer["1 Year"]</option>
                                <option value="3650">@Localizer["10 Years"]</option>
                                <option value="0">@Localizer["Never"]</option>
                            </select>
                            <span asp-validation-for="ExpirationDays" class="text-danger"></span>
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">@Localizer["Generate Key"]</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">@Localizer["Cancel"]</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
