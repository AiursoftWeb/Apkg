@model Aiursoft.Apkg.Models.UserApiKeysViewModels.UserApiKeysIndexViewModel

<div class="container-fluid p-0">
    <div class="row mb-3">
        <div class="col-auto">
            <h1 class="h3 mb-3">@Localizer["Your API Keys"]</h1>
        </div>
        <div class="col-auto ms-auto text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="align-middle me-1" data-lucide="plus"></i>
                @Localizer["Create New Key"]
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h5 class="card-title mb-0">@Localizer["Manage your API keys for uploading packages"]</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>@Localizer["Name"]</th>
                        <th>@Localizer["Key"]</th>
                        <th>@Localizer["Created"]</th>
                        <th>@Localizer["Last Used"]</th>
                        <th>@Localizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Keys.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                @Localizer["You don't have any API keys yet."]
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var key in Model.Keys)
                        {
                            <tr>
                                <td><strong>@key.Name</strong></td>
                                <td><code>@(key.KeyPrefix)...</code></td>
                                <td>@key.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    @if (key.LastUsedAt.HasValue)
                                    {
                                        @key.LastUsedAt.Value.ToString("yyyy-MM-dd HH:mm")
                                    }
                                    else
                                    {
                                        <span class="text-muted">@Localizer["Never"]</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group">
                                        <a asp-action="Usage" asp-route-id="@key.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="align-middle me-1" data-lucide="terminal"></i>
                                            @Localizer["Use"]
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@key.Id" method="post"
                                              onsubmit="return confirm('@Localizer["Are you sure you want to delete this API key?"]');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="align-middle" data-lucide="trash-2"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
